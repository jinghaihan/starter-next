# -----------------------------------------------------------------------------
# Better Auth
# https://www.better-auth.com/docs/installation
# -----------------------------------------------------------------------------
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# -----------------------------------------------------------------------------
# OAuth Providers
# GitHub: https://github.com/settings/developers
# Google: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Database
# Supabase keys: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
SUPABASE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_name
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (Payment)
# Keys/Webhooks: https://dashboard.stripe.com
# Prices: https://dashboard.stripe.com/products
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Pro subscription
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Lifetime one-time payment
STRIPE_PRICE_LIFETIME=

# Credits packages
STRIPE_PRICE_CREDITS_BASIC=
STRIPE_PRICE_CREDITS_STANDARD=
STRIPE_PRICE_CREDITS_PREMIUM=
STRIPE_PRICE_CREDITS_ENTERPRISE=

# -----------------------------------------------------------------------------
# Resend (Mail)
# API keys: https://resend.com/dashboard/api-keys
# Audience: https://resend.com/audiences
# Domains: https://resend.com/domains
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=no-reply@example.com

# -----------------------------------------------------------------------------
# S3 Storage (S3 / Cloudflare R2)
# AWS IAM keys: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html
# R2 S3 API: https://developers.cloudflare.com/r2/get-started/s3/
# -----------------------------------------------------------------------------
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Vercel
# Cron security: https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
# Analytics: https://vercel.com/docs/analytics
# Speed Insights: https://vercel.com/docs/speed-insights
# -----------------------------------------------------------------------------
VERCEL_CRON_SECRET=
VERCEL_ANALYTICS_ENABLED=false
VERCEL_SPEED_INSIGHTS_ENABLED=false

# -----------------------------------------------------------------------------
# Discord (Notification)
# Webhooks: https://support.discord.com/hc/en-us/articles/228383668-Intro-to-Webhooks
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Affonso (Affiliate)
# https://affonso.com/
# -----------------------------------------------------------------------------
AFFONSO_AFFILIATE_ID=
